DATABASE_URL="mysql://root:@localhost:3306/folden_coffe"
JWT_SECRET="supersecretkey"
PORT=5000

# Midtrans Credentials (isi dengan key dari dashboard Midtrans)
# Daftar di https://dashboard.midtrans.com lalu ambil keys dari Settings → Access Keys
# Server Key - rahasia, hanya dipakai di backend
MIDTRANS_SERVER_KEY="SB-Mid-server-xxxxxxxxxxxx"
# Client Key - publik, dipakai di frontend
MIDTRANS_CLIENT_KEY="SB-Mid-client-xxxxxxxxxxxx"
